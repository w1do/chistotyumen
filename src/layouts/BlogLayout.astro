---
import Layout from './Layout.astro';
import HeaderServiceDetails from '../components/landing/HeaderServiceDetails.astro';
import FooterFive from '../components/landing/FooterFive.astro';
import TitleBar from '../components/landing/TitleBar.astro';
import { header, footer, site } from '../data/home';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { resolveImage } from '../lib/images';

interface Props {
	title: string;
	description: string;
	imagePath: string;
	imageAlt: string;
	date?: string;
	author?: string;
	tags?: string[];
	category?: string;
}

const { 
	title, 
	description, 
	imagePath, 
	imageAlt, 
	date = '9 июля, 2026', 
	author = 'Чисто Тюмень',
	tags = [],
	category = 'Клининг'
} = Astro.props;

const phoneTelHref = `tel:${site.phoneTel}`;

// Получаем последние посты для сайдбара
const recentPosts = (await getCollection('posts'))
    .sort((a, b) => {
        const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
        const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
        return dateB - dateA;
    })
    .slice(0, 3);

// Группируем теги для виджета категорий
const allPosts = await getCollection('posts');

// Собираем все теги для облака тегов
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))].slice(0, 8);
---

<Layout title={title} description={description}>
	<Fragment slot="head">
		<meta property="og:type" content="article" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{imagePath && <meta property="og:image" content={new URL(imagePath, Astro.site)} />}
		
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": imagePath ? new URL(imagePath, Astro.site) : undefined,
			"datePublished": date,
			"author": {
				"@type": "Organization",
				"name": "Чисто Тюмень",
				"url": "https://chistotyumen.ru"
			},
			"publisher": {
				"@type": "Organization",
				"name": "Чисто Тюмень",
				"logo": {
					"@type": "ImageObject",
					"url": "https://chistotyumen.ru/images/logo.png"
				}
			},
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": new URL(Astro.url.pathname, Astro.site)
			}
		})} />
	</Fragment>
	<div class="page-wrapper">
		<HeaderServiceDetails 
			header={header} 
			phoneDisplay={site.phone} 
			phoneTelHref={phoneTelHref} 
		/>
		
		<TitleBar 
			heading={title} 
			homeLabel={site.brand}
			homeUrl="/"
			currentLabel={title}
			trailItems={[
				{ label: 'Блог', url: '/posts' },
			]}
		/>

		<div class="page-content"> 
			<section class="site-content blog-details">
				<div class="container">
					<div class="row">
						<div class="col-lg-9 blog-right-col">
							<div class="row">
								<div class="col-md-12">
									<article>
										<div class="post blog-classic">    
											<div class="pbmit-featured-img-wrapper">
												<div class="pbmit-featured-wrapper">
													<Image src={resolveImage(imagePath)} class="img-fluid w-100" alt={imageAlt} />
												</div>
											</div>
											<div class="pbmit-blog-classic-inner">
												<div class="pbmit-blog-meta pbmit-blog-meta-top">
													<span class="pbmit-meta pbmit-meta-cat">
														<a href="/posts" rel="category tag">{category}</a>
													</span>
													<span class="pbmit-meta pbmit-meta-date">
														<i class="pbmit-base-icon-calendar-3"></i>
														<a href="#" rel="bookmark">
															<time class="entry-date published">{date}</time>
														</a>
													</span>
													<span class="pbmit-meta pbmit-meta-author">
														<i class="pbmit-base-icon-user-3"></i>от
														<span class="pbmit-author-link">{author}</span>
													</span>
												</div>
												<div class="pbmit-entry-content">
													<slot />
												</div>
												<style is:global>
													.pbmit-entry-content ul, 
													.pbmit-entry-content ol {
														margin-bottom: 10px;
													}
												</style>
												{tags.length > 0 && (
													<div class="pbmit-blog-meta-bottom">
														<div class="pbmit-blog-meta-bottom-left">
															<span class="pbmit-meta-tags">
																{tags.map(tag => (
																	<a href="#" rel="tag">{tag}</a>
																))}
															</span>
														</div>
													</div>
												)}
											</div>
										</div> 
									</article>
								</div>
							</div>
						</div>
						
						<div class="col-md-12 col-lg-3 blog-left-col">
							<aside class="sidebar">
								<aside class="widget widget-recent-post">
									<h2 class="widget-title">Последние статьи</h2>
									<ul class="recent-post-list">
										{recentPosts.map((post) => (
											<li class="recent-post-list-li">
												<a class="recent-post-thum" href={`/posts/${post.id.split('/').pop()}`}>
													<Image 
														src={resolveImage(post.data.imagePath)} 
														class="img-fluid" 
														alt={post.data.imageAlt} 
														width={150} 
														height={100}
													/>
												</a>
												<div class="pbmit-rpw-content">
													<span class="pbmit-rpw-date">
														<a href={`/posts/${post.id.split('/').pop()}`}>{post.data.date || 'Статья'}</a>
													</span>
													<span class="pbmit-rpw-title">
														<a href={`/posts/${post.id.split('/').pop()}`}>{post.data.title}</a>
													</span>
												</div>
											</li>
										))}
									</ul>
								</aside>
								{allTags.length > 0 && (
									<aside class="widget widget-tag-cloud">
										<h3 class="widget-title">Теги</h3>
										<div class="tagcloud">
											{allTags.map(tag => (
												<a href="#" class="tag-cloud-link">{tag}</a>
											))}
										</div>
									</aside>
								)}
								<aside class="widget pbmit-service-ad">
									<div class="textwidget">
										<div class="pbmit-service-ads">
											<h5 class="pbmit-ads-subheding">Нужна консультация?</h5>
											<h4 class="pbmit-ads-subtitle">Готовы помочь!</h4>
											<h3 class="pbmit-ads-title">Закажите звонок</h3>
											<div class="pbmit-ads-desc">
												<i class="pbmit-base-icon-phone-call-1"></i>{site.phone}
											</div>
											<a class="pbmit-btn pbmit-btn-hover-white" href={site.telegramUrl}>
												<span class="pbmit-button-content-wrapper">
													<span class="pbmit-button-text">Написать в MAX</span>
												</span>
											</a>
										</div>
									</div>
								</aside>
							</aside>
						</div>
					</div>
				</div>
			</section>
		</div>

		<FooterFive data={footer} />
	</div>
</Layout>