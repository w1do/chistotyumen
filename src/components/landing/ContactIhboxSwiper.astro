---
import type { ContactIhboxCard } from '../../data/contact';

interface Props {
  cards: ContactIhboxCard[];
}

const { cards } = Astro.props;
---

<section class="ihbox-section-two">
    <div class="container-fluid p-0">
        <div class="swiper-slider" data-autoplay="false" data-loop="true" data-dots="false" data-arrows="false" data-columns="4" data-margin="30" data-effect="slide">
            <div class="swiper-wrapper">
                {cards.map((card) => (
                    <article class="pbmit-miconheading-style-7 swiper-slide">
                        <div class="pbmit-ihbox-style-7">
                            <div class="pbmit-ihbox-box">
                                <div class="pbmit-icon-wrapper d-flex align-items-center">
                                    <div class="pbmit-ihbox-icon">
                                        <div class="pbmit-ihbox-icon-wrapper">
                                            <div class="pbmit-icon-wrapper pbmit-icon-type-icon">
                                                <i class={card.iconClass} aria-hidden="true"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="pbmit-title-wrap">
                                        <h2 class="pbmit-element-title">{card.title}</h2>
                                    </div>
                                </div>
                                <div class="pbmit-content-wrapper">
                                    <div class="pbmit-heading-desc">{card.description}</div>
                                </div>
                            </div>
                            <div class="pbmit-ihbox-btn">
                                <a class="pbmit-button-inner" href={card.readMoreUrl}>
                                    <span class="pbmit-button-wrapper">
                                        <span class="pbmit-button-text">{card.readMoreLabel}</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </div>
</section>
