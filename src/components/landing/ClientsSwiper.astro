---
import { Image } from 'astro:assets';
import { resolveImage } from '../../lib/images';
import type { ClientLogo } from '../../data/home';

interface Props {
  logos: ClientLogo[];
}

const { logos } = Astro.props;
---

<section class="client-three">
    <div class="container">
        <div class="swiper-slider" data-autoplay="true" data-loop="true" data-dots="false" data-arrows="false" data-columns="6" data-margin="0" data-effect="slide">
            <div class="swiper-wrapper">
                {logos.map((logo) => (
                    <article class="pbmit-client-style-1 swiper-slide">
                        <div class="pbmit-border-wrapper">
                            <div class="pbmit-client-wrapper pbmit-client-with-hover-img">
                                <h4 class="pbmit-hide">{logo.visuallyHiddenTitle}</h4>
                                <div class="pbmit-client-hover-img">
                                    <Image src={resolveImage(logo.hoverImagePath)} class="img-fluid" alt={logo.alt} loading="lazy" />
                                </div>
                                <div class="pbmit-featured-img-wrapper">
                                    <div class="pbmit-featured-wrapper">
                                        <Image src={resolveImage(logo.greyImagePath)} class="img-fluid" alt="" loading="lazy" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </div>
</section>
